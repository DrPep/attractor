  digraph sdlc {
      goal="Build a Python CLI that converts CSV to JSON";
      start [shape=Mdiamond];
      code  [shape=box, prompt="Implement $goal", max_iterations=5];
      test  [shape=box, prompt="Run the tests and report pass/fail"];
      check [shape=diamond];
      done  [shape=Msquare];

      start -> code;
      code  -> test;
      test  -> check;
      check -> code  [label="retry", condition="outcome=fail"];
      check -> done  [condition="outcome=success"];
  }
